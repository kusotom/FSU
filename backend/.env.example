APP_NAME=FSU Monitoring Platform
APP_VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change_me_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=720
ALGORITHM=HS256
DATABASE_URL=postgresql+psycopg://fsu:fsu123456@127.0.0.1:5432/fsu
DB_POOL_SIZE=60
DB_MAX_OVERFLOW=120
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_PRE_PING=true
INGEST_THREAD_TOKENS=320
INGEST_MODE=queue
INGEST_QUEUE_MAXSIZE=50000
INGEST_QUEUE_WORKERS=16
INGEST_QUEUE_WAIT_WHEN_FULL=true
INGEST_QUEUE_BATCH_SIZE=200
INGEST_QUEUE_BATCH_WAIT_MS=80
SYSTEM_RULE_EVAL_ENABLED=false
SYSTEM_RULE_EVAL_INTERVAL_SECONDS=30
SYSTEM_RULE_INLINE_ENABLED=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTO_CREATE_SCHEMA=true

# MQTT bridge (used by scripts/mqtt_ingest_bridge.py)
MQTT_BROKER_HOST=127.0.0.1
MQTT_BROKER_PORT=1883
MQTT_TOPIC=fsu/telemetry/#
MQTT_QOS=1
BACKEND_INGEST_URL=http://127.0.0.1:8000/api/v1/ingest/telemetry
BACKEND_TIMEOUT_SECONDS=5
BACKEND_RETRY_TIMES=2
BRIDGE_QUEUE_MAXSIZE=50000
BRIDGE_WORKER_COUNT=4
BRIDGE_METRICS_PORT=9108
