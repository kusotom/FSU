APP_NAME=FSU Monitoring Platform
APP_VERSION=0.21
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change_me_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=720
ALGORITHM=HS256
DATABASE_URL=postgresql+psycopg://fsu:fsu123456@127.0.0.1:5432/fsu
DB_POOL_SIZE=60
DB_MAX_OVERFLOW=120
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_PRE_PING=true
INGEST_THREAD_TOKENS=320
INGEST_MODE=queue
INGEST_QUEUE_MAXSIZE=50000
INGEST_QUEUE_WORKERS=16
INGEST_QUEUE_WAIT_WHEN_FULL=true
INGEST_QUEUE_BATCH_SIZE=200
INGEST_QUEUE_BATCH_WAIT_MS=80

# DTU gateway (used by scripts/dtu_ingest_gateway.py)
DTU_GATEWAY_ENABLED=false
DTU_GATEWAY_HOST=0.0.0.0
DTU_GATEWAY_PORT=9001
DTU_GATEWAY_PROTOCOL=json_line
DTU_GATEWAY_FRAME_MODE=line
DTU_GATEWAY_FRAME_DELIMITER=\n
DTU_GATEWAY_IDLE_FLUSH_SECONDS=0.5
DTU_GATEWAY_MESSAGE_MAX_BYTES=32768
DTU_GATEWAY_SOCKET_TIMEOUT_SECONDS=0.5
DTU_GATEWAY_BACKEND_INGEST_URL=http://127.0.0.1:8000/api/v1/ingest/dtu
DTU_GATEWAY_BACKEND_TIMEOUT_SECONDS=5
DTU_GATEWAY_BACKEND_RETRY_TIMES=2
DTU_GATEWAY_RAW_LOG_ENABLED=true
DTU_GATEWAY_RAW_LOG_DIR=logs/dtu-raw

# FSU-2808IM passive gateway probe
FSU_GATEWAY_ENABLED=false
FSU_UDP_BIND_HOST=0.0.0.0
FSU_SOAP_PORT=8000
FSU_DSC_PORT=9000
FSU_RDS_PORT=7000
FSU_RAW_LOG_DIR=logs/fsu_raw_packets

SYSTEM_RULE_EVAL_ENABLED=false
SYSTEM_RULE_EVAL_INTERVAL_SECONDS=30
SYSTEM_RULE_INLINE_ENABLED=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTO_CREATE_SCHEMA=true
TIMESCALEDB_AUTO_ENABLE=true

# SMS provider
SMS_PROVIDER=mock
SMS_PHONE_LOGIN_ENABLED=true

# Tencent SMS (important alarm fallback)
SMS_TENCENT_ENABLED=false
SMS_TENCENT_SECRET_ID=
SMS_TENCENT_SECRET_KEY=
SMS_TENCENT_SDK_APP_ID=
SMS_TENCENT_SIGN_NAME=
SMS_TENCENT_TEMPLATE_ID=
SMS_TENCENT_REGION=ap-guangzhou
SMS_TENCENT_TEMPLATE_MODE=single_text

# UniSMS (phone login / activation)
UNISMS_ENABLED=false
UNISMS_ACCESS_KEY_ID=
UNISMS_ACCESS_KEY_SECRET=
UNISMS_HMAC_ENABLED=true
UNISMS_BASE_URL=https://uni.apistd.com
UNISMS_SMS_SIGNATURE=
UNISMS_LOGIN_TEMPLATE_ID=
UNISMS_DLR_VERIFY_ENABLED=true
UNISMS_DLR_SECRET=
UNISMS_CONNECT_TIMEOUT_SECONDS=5
UNISMS_READ_TIMEOUT_SECONDS=10

# SMS auth policy
SMS_CODE_LENGTH=6
SMS_CODE_EXPIRE_SECONDS=300
SMS_SEND_INTERVAL_SECONDS=60
SMS_SEND_LIMIT_PER_10M=5
SMS_VERIFY_MAX_ATTEMPTS=5
SMS_LOGIN_FAIL_LOCK_THRESHOLD=10
SMS_LOGIN_LOCK_MINUTES=30
SMS_IP_LIMIT_PER_MINUTE=30
SMS_IP_LIMIT_PER_HOUR=200

# MQTT bridge (used by scripts/mqtt_ingest_bridge.py)
MQTT_BROKER_HOST=127.0.0.1
MQTT_BROKER_PORT=1883
MQTT_TOPIC=fsu/telemetry/#
MQTT_QOS=1
BACKEND_INGEST_URL=http://127.0.0.1:8000/api/v1/ingest/telemetry
BACKEND_TIMEOUT_SECONDS=5
BACKEND_RETRY_TIMES=2
BRIDGE_QUEUE_MAXSIZE=50000
BRIDGE_WORKER_COUNT=4
BRIDGE_METRICS_PORT=9108
