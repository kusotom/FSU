APP_NAME=FSU Monitoring Platform
APP_VERSION=0.21
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change_me_to_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=720
ALGORITHM=HS256
DATABASE_URL=postgresql+psycopg://fsu:fsu123456@127.0.0.1:5432/fsu
DB_POOL_SIZE=60
DB_MAX_OVERFLOW=120
DB_POOL_TIMEOUT_SECONDS=30
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_PRE_PING=true
INGEST_THREAD_TOKENS=320
INGEST_MODE=queue
INGEST_QUEUE_MAXSIZE=50000
INGEST_QUEUE_WORKERS=16
INGEST_QUEUE_WAIT_WHEN_FULL=true
INGEST_QUEUE_BATCH_SIZE=200
INGEST_QUEUE_BATCH_WAIT_MS=80
SYSTEM_RULE_EVAL_ENABLED=false
SYSTEM_RULE_INLINE_ENABLED=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTO_CREATE_SCHEMA=true
TIMESCALEDB_AUTO_ENABLE=true

# SMS provider
SMS_PROVIDER=unisms
SMS_PHONE_LOGIN_ENABLED=true

# UniSMS (phone login / activation)
UNISMS_ENABLED=true
UNISMS_ACCESS_KEY_ID=your_access_key_id
UNISMS_ACCESS_KEY_SECRET=your_access_key_secret
UNISMS_HMAC_ENABLED=true
UNISMS_BASE_URL=https://uni.apistd.com
UNISMS_SMS_SIGNATURE=your_sms_signature
UNISMS_LOGIN_TEMPLATE_ID=your_login_template_id
UNISMS_DLR_VERIFY_ENABLED=true
UNISMS_DLR_SECRET=change_me_unisms_dlr_secret
UNISMS_CONNECT_TIMEOUT_SECONDS=5
UNISMS_READ_TIMEOUT_SECONDS=10

# SMS auth policy
SMS_CODE_LENGTH=6
SMS_CODE_EXPIRE_SECONDS=300
SMS_SEND_INTERVAL_SECONDS=60
SMS_SEND_LIMIT_PER_10M=5
SMS_VERIFY_MAX_ATTEMPTS=5
SMS_LOGIN_FAIL_LOCK_THRESHOLD=10
SMS_LOGIN_LOCK_MINUTES=30
SMS_IP_LIMIT_PER_MINUTE=30
SMS_IP_LIMIT_PER_HOUR=200

# Keep Tencent SMS disabled when UniSMS is the login provider
SMS_TENCENT_ENABLED=false
SMS_TENCENT_SECRET_ID=
SMS_TENCENT_SECRET_KEY=
SMS_TENCENT_SDK_APP_ID=
SMS_TENCENT_SIGN_NAME=
SMS_TENCENT_TEMPLATE_ID=
SMS_TENCENT_REGION=ap-guangzhou
SMS_TENCENT_TEMPLATE_MODE=single_text
